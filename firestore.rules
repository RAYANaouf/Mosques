rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    match /students/{studentId} {
      allow read, write: if true;
    }

    match /teachers/{teacherId} {
      allow read, write: if true;
    }

    match /groups/{groupId} {
      allow read, write: if true;
    }

    match /events/{eventId} {
      allow read, write: if true;
    }
  }
}
